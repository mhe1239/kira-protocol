rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list, create, update, delete: if false;
    }

    match /diseaseRecords/{recordId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 'note', 'status', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() <= 240))
        && request.resource.data.status in ['대기', '관찰', '확정', '해결'];
      allow delete: if isAdmin();
      allow update: if false;
    }
  }
}
